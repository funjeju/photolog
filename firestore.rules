rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // users — 본인만 read/write
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // posts — 본인 것만
      match /posts/{postId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        // photos — 본인 것만
        match /photos/{photoId} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }

      // videos — 본인 것만
      match /videos/{videoId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
